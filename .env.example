# =====================================================
# VivBlendz — Environment Variables
# Copy this file to .env.local and fill in all values.
# =====================================================

# ----- Supabase (required) -------------------------
# Get these from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- Resend email (required) ---------------------
# Get your key at: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ----- Owner email (required) ----------------------
# This is where YOUR booking notification emails go
OWNER_EMAIL=yourname@gmail.com

# ----- Admin panel password (required) -------------
# Change this to something strong — it protects /admin
ADMIN_PASSWORD=change-me-now

# ----- Google Calendar (optional) ------------------
# Auto-adds each booking to your Google Calendar.
# Setup guide: see README_SETUP.md → Google Calendar section
#
# GOOGLE_CALENDAR_ID: your calendar's ID (Settings → Integrate calendar → Calendar ID)
# GOOGLE_SERVICE_ACCOUNT_KEY: the full JSON content of your service account key file
#   (paste it as one line, or use a multiline env var in your hosting platform)
GOOGLE_CALENDAR_ID=your-calendar-id@gmail.com
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ----- Base URL ------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
